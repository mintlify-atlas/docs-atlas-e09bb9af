  "keyFeatures": [
    "Multi-company tenant management with role-based access control",
    "Complete accounting system with chart of accounts and journal entries",
    "Chilean tax compliance with Form 29 and DTE document management",
    "Intelligent bank reconciliation with automated matching algorithms",
    "Payment gateway integrations (MercadoPago, Flow)",
    "SII integration for tax document validation and submission",
    "Audit logging and comprehensive financial reporting",
    "Real-time dashboard with financial metrics and alerts"
  ],
  "publicApiSurface": [
    "POST /api/auth/register - Register new user",
    "POST /api/auth/login - Authenticate user",
    "GET /api/auth/me - Get current user profile",
    "GET /api/accounting/journal - Retrieve journal entries",
    "POST /api/accounting/proposals/save - Create accounting proposal",
    "GET /api/accounting/mayor/:accountId - Get ledger for account",
    "POST /api/ingest/dte - Upload DTE documents",
    "GET /api/tax-forms/f29 - Retrieve Form 29 data",
    "POST /api/tax-forms/f29 - Generate Form 29",
    "GET /api/reconciliation/suggestions - Get matching suggestions",
    "POST /api/reconciliation/match - Create reconciliation match",
    "POST /api/reconciliation/reverse - Reverse reconciliation",
    "GET /api/entities - List customers/suppliers",
    "POST /api/entities - Create new entity",
    "GET /api/integrations/mercadopago/movements - Get MercadoPago transactions",
    "POST /api/webhooks/mercadopago - MercadoPago webhook handler"
  ]
